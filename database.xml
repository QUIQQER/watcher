<?xml version="1.0" encoding="UTF-8"?>
<database>

    <global>
        <table name="watcher" no-site-reference="1" no-auto-update="1">
            <field type="bigint" autoincrement="true" primary="true">id</field>
            <field type="text" nullable="true" default="null">message</field>
            <field type="string" length="255" nullable="true" default="null">localeGroup</field>
            <field type="string" length="255" nullable="true" default="null">localeVar</field>
            <field type="text" nullable="true" default="null">localeParams</field>
            <field type="string" length="50">uid</field>
            <field type="datetime" nullable="true" default="null">statusTime</field>
            <field type="string" length="255" nullable="true" default="null">call</field>
            <field type="text" nullable="true" default="null">callParams</field>

            <index>uid</index>
            <index>statusTime</index>
            <index>uid,statusTime</index>
        </table>

        <table name="watcherEvents" no-site-reference="1" no-auto-update="1">
            <field type="bigint" autoincrement="true" primary="true">id</field>
            <field type="string" length="255" nullable="true" default="null">package</field>
            <field type="string" length="255" nullable="true" default="null">ajax</field>
            <field type="string" length="255" nullable="true" default="null">event</field>
            <field type="text" nullable="true" default="null">exec</field>

            <index>package</index>
        </table>
    </global>

</database>
